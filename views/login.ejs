<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Document Control System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'DM Sans', sans-serif; }
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: linear-gradient(135deg, #1B1C31, #0d5f5f);
      margin: 0;
    }
    .login-card {
      background: white;
      padding: 50px 40px;
      border-radius: 20px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.1);
      max-width: 420px;
      width: 100%;
    }
    .logo-box {
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, #0d5f5f, #23a6a6);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 24px;
      font-size: 24px;
      font-weight: 700;
      color: white;
      font-family: 'Barlow Condensed', sans-serif;
    }
    .login-card h2 {
      text-align: center;
      font-size: 24px;
      font-weight: 700;
      color: #1a2332;
      margin-bottom: 8px;
      font-family: 'Barlow Condensed', sans-serif;
    }
    .login-card .subtext {
      text-align: center;
      font-size: 13px;
      color: #9ca3af;
      margin-bottom: 24px;
    }
    .form-control {
      background-color: #F8FAFC;
      border: 1px solid #E0E7FF;
      border-radius: 10px;
      padding: 12px 16px;
      font-size: 14px;
      color: #1a2332;
      margin-bottom: 16px;
    }
    .form-control:focus {
      border-color: #1a7a7a;
      box-shadow: 0 0 0 3px rgba(26,122,122,0.1);
    }
    .btn-signin {
      background-color: #1a7a7a;
      color: white;
      border: none;
      border-radius: 10px;
      padding: 12px 16px;
      font-size: 14px;
      font-weight: 600;
      width: 100%;
      cursor: pointer;
      margin-top: 8px;
    }
    .btn-signin:hover {
      background-color: #0d5f5f;
      transform: translateY(-2px);
    }
    .alert-danger {
      border-radius: 10px;
      border: none;
      background-color: #FEE4E2;
      color: #C23B22;
      margin-bottom: 20px;
      font-size: 13px;
    }
    label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #1a2332;
      margin-bottom: 8px;
    }
    .footer-text {
      text-align: center;
      font-size: 11px;
      color: #9ca3af;
      margin-top: 24px;
    }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo-box">DC</div>
    <h2>Document Control System</h2>
    <p class="subtext">Construction Project · Integrated Document Register</p>

    <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <form method="POST" action="/login">
      <label for="email">Email Address</label>
      <input type="email" class="form-control" id="email" name="email" placeholder="admin@dcs.com" required>

      <label for="password">Password</label>
      <input type="password" class="form-control" id="password" name="password" placeholder="••••••••" required>

      <button type="submit" class="btn-signin">Sign In →</button>
    </form>

    <div class="footer-text">
      © 2025 Document Control System · Prepared by Israr Khan — Sr. Document Controller
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
