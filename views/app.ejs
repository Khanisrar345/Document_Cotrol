                    </label>
                  </div>
                <% }); %>
              <% } else { %>
                <p style="color: #9ca3af; margin: 0;">No available documents.</p>
              <% } %>
            </div>
          </div>

          <div style="display: flex; gap: 12px;">
            <button type="submit" class="btn-primary-custom">
              <i class="fas fa-save"></i> Create Transmittal
            </button>
            <a href="/app?page=transmittals" class="btn-primary-custom" style="background-color: #9ca3af;">
              Cancel
            </a>
          </div>
        </form>
      </div>
    <% } %>

    <!-- Revisions -->
    <% if (page === 'revisions') { %>
      <div class="card" style="padding: 20px;">
        <div style="overflow-x: auto;">
          <table class="table">
            <thead>
              <tr>
                <th>Doc Number</th>
                <th>Type</th>
                <th>Rev</th>
                <th>Change Note</th>
                <th>Changed By</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% if (revisions && revisions.length > 0) { %>
                <% revisions.forEach(rev => { %>
                  <tr>
                    <td><strong><%= rev.document_id && rev.document_id.doc_number ? rev.document_id.doc_number : 'N/A' %></strong></td>
                    <td><span class="badge-type"><%= rev.document_id && rev.document_id.type ? rev.document_id.type : 'N/A' %></span></td>
                    <td><%= rev.rev %></td>
                    <td><%= rev.change_note || 'N/A' %></td>
                    <td><%= rev.changed_by && rev.changed_by.full_name ? rev.changed_by.full_name : 'System' %></td>
                    <td><%= new Date(rev.changed_at).toLocaleDateString() %></td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="6" style="text-align: center; padding: 20px; color: #9ca3af;">No revisions found.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

    <!-- Manage Users (Admin) -->
    <% if (page === 'manage_users' && user.role === 'admin') { %>
      <div style="margin-bottom: 20px;">
        <button class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#addUserModal">
          <i class="fas fa-plus"></i> Add User
        </button>
      </div>

      <div class="card" style="padding: 20px;">
        <div style="overflow-x: auto;">
          <table class="table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Company</th>
                <th>Phone</th>
                <th>Created</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (users && users.length > 0) { %>
                <% users.forEach(u => { %>
                  <tr>
                    <td><strong><%= u.full_name %></strong></td>
                    <td><%= u.email %></td>
                    <td><span class="badge-role"><%= u.role %></span></td>
                    <td><%= u.company || 'N/A' %></td>
                    <td><%= u.phone || 'N/A' %></td>
                    <td><%= new Date(u.created_at).toLocaleDateString() %></td>
                    <td>
                      <% if (u._id.toString() !== user._id.toString()) { %>
                        <a href="/app?page=manage_users&delete=true&table=users&id=<%= u._id %>" class="btn-danger-custom" onclick="return confirm('Delete this user?');">
                          <i class="fas fa-trash"></i>
                        </a>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="7" style="text-align: center; padding: 20px; color: #9ca3af;">No users found.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Add User Modal -->
      <div class="modal fade" id="addUserModal" tabindex="-1">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title">Add New User</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="POST" action="/app">
              <div class="modal-body">
                <input type="hidden" name="action" value="add_user">

                <div class="form-group">
                  <label>Full Name</label>
                  <input type="text" name="full_name" required>
                </div>

                <div class="form-group">
                  <label>Email</label>
                  <input type="email" name="email" required>
                </div>

                <div class="form-group">
                  <label>Password</label>
                  <input type="password" name="password" placeholder="Default: 123456">
                </div>

                <div class="form-group">
                  <label>Role</label>
                  <select name="role" required>
                    <option value="admin">Admin</option>
                    <option value="staff">Staff (Document Controller)</option>
                    <option value="contractor">Contractor</option>
                    <option value="viewer">Viewer</option>
                  </select>
                </div>

                <div class="form-group">
                  <label>Company</label>
                  <input type="text" name="company" placeholder="e.g., XYZ Contractors Ltd">
                </div>

                <div class="form-group">
                  <label>Phone</label>
                  <input type="text" name="phone">
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn-primary-custom">Add User</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Reports -->
    <% if (page === 'reports') { %>
      <div style="margin-bottom: 12px;">
        <button class="btn-primary-custom" onclick="window.print()">
          <i class="fas fa-print"></i> Print
        </button>
        <button class="btn-primary-custom" style="background-color: #9ca3af; margin-left: 4px;" onclick="exportCSV()">
          <i class="fas fa-download"></i> Export CSV
        </button>
      </div>

      <!-- KPI Cards -->
      <div class="row">
        <div class="col-md-6 col-lg-4">
          <div class="kpi-card teal">
            <div>
              <div class="kpi-label">Total Documents</div>
              <div class="kpi-value"><%= total_documents || 0 %></div>
            </div>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="kpi-card green">
            <div>
              <div class="kpi-label">Approved</div>
              <div class="kpi-value"><%= approved_count || 0 %></div>
            </div>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="kpi-card orange">
            <div>
              <div class="kpi-label">Approval Rate</div>
              <div class="kpi-value"><%= approval_rate || 0 %>%</div>
            </div>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="kpi-card red">
            <div>
              <div class="kpi-label">Overdue</div>
              <div class="kpi-value"><%= overdue_count || 0 %></div>
            </div>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="kpi-card blue">
            <div>
              <div class="kpi-label">Under Review</div>
              <div class="kpi-value"><%= review_count || 0 %></div>
            </div>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="kpi-card purple">
            <div>
              <div class="kpi-label">Transmittals</div>
              <div class="kpi-value"><%= total_transmittals || 0 %></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Overdue Documents -->
      <div class="card" style="margin-top: 20px; padding: 20px;">
        <h5>Overdue Documents</h5>
        <div style="overflow-x: auto;">
          <table class="table">
            <thead>
              <tr>
                <th>Doc Number</th>
                <th>Type</th>
                <th>Title</th>
                <th>Contractor</th>
                <th>Due Date</th>
                <th>Days Overdue</th>
              </tr>
            </thead>
            <tbody>
              <% if (overdue_docs && overdue_docs.length > 0) { %>
                <% overdue_docs.forEach(doc => { %>
                  <tr>
                    <td><strong><%= doc.doc_number %></strong></td>
                    <td><span class="badge-type"><%= doc.type %></span></td>
                    <td><%= doc.title.substring(0, 30) %>...</td>
                    <td><%= doc.contractor || 'N/A' %></td>
                    <td><%= doc.due_date ? new Date(doc.due_date).toLocaleDateString() : 'N/A' %></td>
                    <td><span class="days-open-red"><%= doc.days_open %></span></td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="6" style="text-align: center; padding: 20px; color: #9ca3af;">No overdue documents.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <script>
        function exportCSV() {
          const table = document.querySelector('table');
          let csv = [];
          const rows = table.querySelectorAll('tr');
          rows.forEach(row => {
            const cols = row.querySelectorAll('td, th');
            const csvRow = Array.from(cols).map(col => '"' + col.innerText.replace(/"/g, '""') + '"').join(',');
            csv.push(csvRow);
          });
          const csvContent = 'data:text/csv;charset=utf-8,' + csv.join('\n');
          const link = document.createElement('a');
          link.setAttribute('href', encodeURI(csvContent));
          link.setAttribute('download', 'Reports_' + new Date().toISOString().split('T')[0] + '.csv');
          link.click();
        }
      </script>
    <% } %>

    <!-- Notifications (Admin) -->
    <% if (page === 'notifications' && user.role === 'admin') { %>
      <div class="row">
        <div class="col-lg-6">
          <div class="card" style="padding: 20px; margin-bottom: 20px;">
            <h5>Send Notification</h5>
            <form method="POST" action="/app">
              <input type="hidden" name="action" value="send_notification">

              <div class="form-group">
                <label>Audience</label>
                <select name="type" required>
                  <option value="all">All Users</option>
                  <option value="admin">Admin</option>
                  <option value="staff">Staff</option>
                  <option value="contractor">Contractor</option>
                  <option value="viewer">Viewer</option>
                </select>
              </div>

              <div class="form-group">
                <label>Message</label>
                <textarea name="message" rows="3" required></textarea>
              </div>

              <button type="submit" class="btn-primary-custom">
                <i class="fas fa-paper-plane"></i> Send
              </button>
            </form>
          </div>
        </div>
      </div>

      <div class="card" style="padding: 20px; margin-bottom: 20px;">
        <h5>Leave/Absence Requests</h5>
        <div style="overflow-x: auto;">
          <table class="table">
            <thead>
              <tr>
                <th>User</th>
                <th>Role</th>
                <th>Date</th>
                <th>Message</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (leaves && leaves.length > 0) { %>
                <% leaves.forEach(leave => { %>
                  <tr>
                    <td><strong><%= leave.user_id && leave.user_id.full_name ? leave.user_id.full_name : 'N/A' %></strong></td>
                    <td><span class="badge-role"><%= leave.role %></span></td>
                    <td><%= leave.date %></td>
                    <td><%= leave.message.substring(0, 30) %>...</td>
                    <td><span class="badge-status <%= leave.status.toLowerCase() %>"><%= leave.status %></span></td>
                    <td>
                      <% if (leave.status === 'Pending') { %>
                        <form method="POST" action="/app" style="display: flex; gap: 4px;">
                          <input type="hidden" name="action" value="update_leave">
                          <input type="hidden" name="leave_id" value="<%= leave._id %>">
                          <input type="hidden" name="status" value="Approved">
                          <button type="submit" class="btn-success-custom">Approve</button>
                        </form>
                        <form method="POST" action="/app" style="display: inline;">
                          <input type="hidden" name="action" value="update_leave">
                          <input type="hidden" name="leave_id" value="<%= leave._id %>">
                          <input type="hidden" name="status" value="Declined">
                          <button type="submit" class="btn-danger-custom">Decline</button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="6" style="text-align: center; padding: 20px; color: #9ca3af;">No leave requests.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="card" style="padding: 20px;">
        <h5>All Notifications</h5>
        <% if (notifications && notifications.length > 0) { %>
          <% notifications.forEach(notif => { %>
            <div class="notif-card">
              <div class="notif-message"><%= notif.message %></div>
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <div class="notif-time"><%= new Date(notif.created_at).toLocaleDateString() %></div>
                <a href="/app?page=notifications&delete=true&table=notifications&id=<%= notif._id %>" class="btn-danger-custom">
                  <i class="fas fa-trash"></i>
                </a>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <p style="color: #9ca3af;">No notifications.</p>
        <% } %>
      </div>
    <% } %>

    <!-- My Notifications -->
    <% if (page === 'my_notifications') { %>
      <% if (notifs && notifs.length > 0) { %>
        <% notifs.forEach(notif => { %>
          <div class="notif-card">
            <i class="fas fa-bell" style="color: var(--accent); margin-right: 12px;"></i>
            <div class="notif-message"><%= notif.message %></div>
            <div class="notif-time"><%= new Date(notif.created_at).toLocaleDateString() %></div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="alert alert-info">
          <i class="fas fa-info-circle"></i> No notifications for you.
        </div>
      <% } %>
    <% } %>

    <!-- Apply Leave -->
    <% if (page === 'apply_leave') { %>
      <div class="row">
        <div class="col-lg-6">
          <div class="card" style="padding: 20px;">
            <h5>Apply for Leave</h5>
            <form method="POST" action="/app">
              <input type="hidden" name="action" value="apply_leave">

              <div class="form-group">
                <label>Date</label>
                <input type="date" name="date" required>
              </div>

              <div class="form-group">
                <label>Reason</label>
                <textarea name="message" rows="4" required></textarea>
              </div>

              <button type="submit" class="btn-primary-custom">
                <i class="fas fa-check"></i> Submit Request
              </button>
            </form>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="card" style="padding: 20px;">
            <h5>My Leave History</h5>
            <% if (my_leaves && my_leaves.length > 0) { %>
              <% my_leaves.forEach(leave => { %>
                <div style="padding: 12px; background: #F8FAFC; border-radius: 10px; margin-bottom: 12px;">
                  <div style="display: flex; justify-content: space-between;">
                    <div>
                      <div style="font-weight: 600;"><%= leave.date %></div>
                      <div style="font-size: 12px; color: #9ca3af;"><%= leave.message.substring(0, 40) %>...</div>
                    </div>
                    <span class="badge-status <%= leave.status.toLowerCase() %>"><%= leave.status %></span>
                  </div>
                </div>
              <% }); %>
            <% } else { %>
              <p style="color: #9ca3af;">No leave requests.</p>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Feedback -->
    <% if (page === 'feedback') { %>
      <% if (user.role === 'admin' || user.role === 'staff') { %>
        <!-- View Feedback -->
        <div class="card" style="padding: 20px;">
          <h5>All Feedback</h5>
          <div style="overflow-x: auto;">
            <table class="table">
              <thead>
                <tr>
                  <th>User</th>
                  <th>Role</th>
                  <th>Message</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <% if (feedbacks && feedbacks.length > 0) { %>
                  <% feedbacks.forEach(fb => { %>
                    <tr>
                      <td><strong><%= fb.user_id && fb.user_id.full_name ? fb.user_id.full_name : 'Anonymous' %></strong></td>
                      <td><span class="badge-role"><%= fb.user_id && fb.user_id.role ? fb.user_id.role : 'N/A' %></span></td>
                      <td><%= fb.message.substring(0, 50) %>...</td>
                      <td><%= new Date(fb.created_at).toLocaleDateString() %></td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr><td colspan="4" style="text-align: center; padding: 20px; color: #9ca3af;">No feedback received.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      <% } else { %>
        <!-- Send Feedback -->
        <div class="card" style="padding: 24px; max-width: 600px;">
          <h5>Send Feedback</h5>
          <form method="POST" action="/app">
            <input type="hidden" name="action" value="send_feedback">

            <div class="form-group">
              <label>Your Feedback</label>
              <textarea name="message" rows="5" placeholder="Share your thoughts, suggestions, or concerns..." required></textarea>
            </div>

            <button type="submit" class="btn-primary-custom">
              <i class="fas fa-paper-plane"></i> Submit Feedback
            </button>
          </form>
        </div>
      <% } %>
    <% } %>

    <!-- My Submissions (Contractor) -->
    <% if (page === 'my_submissions' && user.role === 'contractor') { %>
      <div class="card" style="padding: 20px;">
        <div style="overflow-x: auto;">
          <table class="table">
            <thead>
              <tr>
                <th>Doc Number</th>
                <th>Type</th>
                <th>Title</th>
                <th>Status</th>
                <th>Submitted</th>
                <th>Response Due</th>
              </tr>
            </thead>
            <tbody>
              <% if (documents && documents.length > 0) { %>
                <% documents.forEach(doc => { %>
                  <tr>
                    <td><strong><%= doc.doc_number %></strong></td>
                    <td><span class="badge-type"><%= doc.type %></span></td>
                    <td><%= doc.title.substring(0, 40) %>...</td>
                    <td><span class="badge-status <%= doc.status.toLowerCase().replace(/ /g, '-').replace(/&/g, 'and') %>"><%= doc.status %></span></td>
                    <td><%= doc.issue_date ? new Date(doc.issue_date).toLocaleDateString() : 'N/A' %></td>
                    <td><%= doc.due_date ? new Date(doc.due_date).toLocaleDateString() : 'N/A' %></td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="6" style="text-align: center; padding: 20px; color: #9ca3af;">No submissions found.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

    <div class="footer-text">
      © 2025 Document Control System · Prepared by Israr Khan — Sr. Document Controller
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.getElementById('importBtn')?.addEventListener('click', async () => {
      const fileInput = document.getElementById('jsonImport');
      const file = fileInput.files[0];
      if (!file) {
        alert('Please select a JSON file');
        return;
      }

      const text = await file.text();
      const data = JSON.parse(text);

      const res = await fetch('/import-json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ data })
      });

      const result = await res.json();
      const msg = `✅ Imported ${result.imported} documents, ${result.skipped} skipped${result.errors.length > 0 ? ', ' + result.errors.length + ' errors' : ''}`;
      document.getElementById('importResult').textContent = msg;
      setTimeout(() => location.reload(), 1500);
    });
  </script>
</body>
</html>
